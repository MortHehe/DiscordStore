DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_test_guild_id_here
ADMIN_ROLE_ID=your_admin_role_id_here
NEW_MEMBER_ROLE_ID=role_given_to_every_new_joiner
BUYER_ROLE_ID=role_given_to_verified_buyers
SALE_LOG_CHANNEL_ID=channel_for_sale_logs_admin_only
PUBLIC_SALE_LOG_CHANNEL_ID=channel_visible_to_everyone_for_social_proof
PUBLIC_LOG_SHOW_GIFTS=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=discord_store
LOG_LEVEL=info
PANEL_REFRESH_MINUTES=5

# IMAP (for /searchemail — email admin, bukan customer)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_admin_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password

# Payment provider — one of: manual | paydisini | autogopay
PAYMENT_PROVIDER=autogopay

# AutoGoPay (sawargipay.cloud)
AUTOGOPAY_API_KEY=paste_your_autogopay_api_key
AUTOGOPAY_CONFIRM_MODE=polling
# ^ polling | webhook | both
AUTOGOPAY_WEBHOOK_PORT=3000
AUTOGOPAY_WEBHOOK_PATH=/autogopay/callback

# Polling interval (used when confirm mode is polling or both)
PAYMENT_POLL_INTERVAL=15

# Paydisini (not in use currently)
# PAYDISINI_API_KEY=
# PAYDISINI_VALID_TIME=840
