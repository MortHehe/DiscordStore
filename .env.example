DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here
GUILD_ID=your_test_guild_id_here
ADMIN_ROLE_ID=your_admin_role_id_here
NEW_MEMBER_ROLE_ID=role_given_to_every_new_joiner
BUYER_ROLE_ID=role_given_to_verified_buyers
SALE_LOG_CHANNEL_ID=channel_for_sale_logs_admin_only
PUBLIC_SALE_LOG_CHANNEL_ID=channel_visible_to_everyone_for_social_proof
PUBLIC_LOG_SHOW_GIFTS=false
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=discord_store
LOG_LEVEL=info
PANEL_REFRESH_MINUTES=5

# IMAP (for /searchemail — email admin, bukan customer)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your_admin_email@gmail.com
IMAP_PASSWORD=your_gmail_app_password

# Mass Link tool (admin only — for Pixel World account management)
# Steam App ID + PlayFab Title ID dari game target
# Default: Growtopia (636040 / 11EF5C). Pixel Worlds = 871980
GAME_STEAM_APP_ID=636040
GAME_PLAYFAB_TITLE_ID=11EF5C
UNITY_VERSION=6000.3.11f1
PLAYFAB_SDK=UnitySDK-2.178.230929
MASSLINK_CONCURRENCY=3
MASSLINK_UNLINK_RETRIES=5

# Steam ticket retry tuning
STEAM_LICENSE_RETRIES=3
STEAM_LICENSE_DELAY_MS=2500
STEAM_POST_LICENSE_WAIT_MS=3000
# Set TRUE kalau akun sudah punya PixelWorlds (skip free license claim)
STEAM_SKIP_FREE_LICENSE=false

# Role yang bisa pakai /masslink (selain admin) — kosongkan = admin only
MASSLINK_ROLE_ID=
# Atau whitelist user ID spesifik (comma-separated)
MASSLINK_ALLOW_USER_IDS=

# Option A — inline list (comma-separated)
# Format: protocol://[user:pass@]host:port  OR  protocol://[user:pass@]host:from-to
# Mix HTTP/SOCKS5 supported. HTTP only works for PlayFab; Steam needs SOCKS5.
MASSLINK_PROXIES=

# Option B — separate config (rotating proxy, single host, port range)
# Bot akan random pick port dari [PORT_FROM..PORT_TO] tiap request.
# MASSLINK_PROXY_PROTOCOL=socks5
# MASSLINK_PROXY_HOST=gate.proxyprovider.com
# MASSLINK_PROXY_USERNAME=
# MASSLINK_PROXY_PASSWORD=
# MASSLINK_PROXY_PORT_FROM=10000
# MASSLINK_PROXY_PORT_TO=10999

# Payment provider — one of: manual | paydisini | autogopay
PAYMENT_PROVIDER=autogopay

# AutoGoPay (sawargipay.cloud)
AUTOGOPAY_API_KEY=paste_your_autogopay_api_key
AUTOGOPAY_CONFIRM_MODE=polling
# ^ polling | webhook | both
AUTOGOPAY_WEBHOOK_PORT=3000
AUTOGOPAY_WEBHOOK_PATH=/autogopay/callback

# Polling interval (used when confirm mode is polling or both)
PAYMENT_POLL_INTERVAL=15

# Paydisini (not in use currently)
# PAYDISINI_API_KEY=
# PAYDISINI_VALID_TIME=840
